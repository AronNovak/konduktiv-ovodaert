{#
  Header layout:
  - Foundation logo + Pető ovi logo on the left, both link to home.
  - Inline horizontal main menu in the center on lg+.
  - A clearly visible Facebook link, then a burger menu (only below lg).
#}
<div class="container-wide relative py-3 md:py-4">
  <div class="flex items-center gap-4 md:gap-6">

    {# Both logos linked to the homepage. The foundation logo image already contains the name. #}
    <a href="{{ path('<front>') }}" class="flex items-center gap-3 md:gap-5 shrink-0" id="main-logo" aria-label="{{ site_name }}">
      <img src="/{{ directory }}/dist/images/logo-foundation.png" alt="{{ site_name }}" class="h-12 md:h-16 w-auto">
      <img src="/{{ directory }}/dist/images/logo-petoovi.png" alt="{{ 'Pető ovi'|t }}" class="hidden sm:block h-10 md:h-14 w-auto">
    </a>

    {# Desktop horizontal nav. The mobile/burger overlay still renders via page.primary_menu. #}
    <nav class="hidden lg:flex grow justify-center items-center text-sm font-display font-semibold uppercase tracking-wide" role="navigation" aria-label="{{ 'Main menu'|t }}">
      {{ inline_menu }}
    </nav>

    <div class="ms-auto lg:ms-0 flex items-center gap-3">
      {# Facebook link, like the source Wix site. #}
      <a href="https://www.facebook.com/konduktivovialapitvany/" target="_blank" rel="noopener" title="Facebook" aria-label="Facebook" class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-primary text-white hover:bg-brand-primary-dark focus-visible:bg-brand-primary-dark transition-colors duration-200">
        <i class="fab fa-facebook-f text-lg" aria-hidden="true"></i>
      </a>

      {# Burger menu only on screens below lg (where the inline menu is hidden). #}
      <button type="button" name="open_menu" class="lg:hidden js-open-menu flex items-center gap-x-2 px-2 py-2 border border-transparent hover:border-brand-primary focus-visible:border-brand-primary text-brand-ink transition-colors duration-200" aria-label="{{ 'Menu'|t }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3.75 6.75H20.25M3.75 12H20.25M3.75 17.25H20.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="hidden sm:inline" id="header-menu">{{ 'Menu'|t }}</span>
      </button>
    </div>
  </div>

  {{ messages }}
</div>
