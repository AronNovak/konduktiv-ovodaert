      <div class="text-sm leading-relaxed">
        2011 Budakalász, Kossuth L. u. 7.<br>
        <a href="mailto:petoovialapitvany@gmail.com" class="underline hover:text-brand-yellow">petoovialapitvany@gmail.com</a>
      </div>
    </div>

    <div>
      <div class="font-display text-lg font-semibold mb-2">{{ 'Adószám'|t }}</div>
