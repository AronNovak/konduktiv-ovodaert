{% macro socialMedia(name, url, label) %}
  <a href="{{ url }}" target="_blank" rel="noopener" title="{{ label }}" class="hover:text-brand-yellow transition-colors duration-200">
    <i class="fab fa-lg fa-{{ name }}"></i>
  </a>
{% endmacro %}

