{% set is_download = button_type == 'download' %}
{# `Download` button uses the same look as a `secondary` button #}
{% set actual_button_type = is_download ? 'secondary' : button_type %}

{% set classes = [
  'flex flex-row items-center gap-x-4 rounded-full px-6 py-3 text-lg font-display font-semibold border-2 border-brand-primary w-fit transition duration-300',
  actual_button_type == 'primary' ? 'bg-brand-primary text-white hover:bg-brand-primary-dark hover:border-brand-primary-dark focus-visible:bg-brand-primary-dark focus-visible:border-brand-primary-dark',
  actual_button_type == 'secondary' ? 'text-brand-primary bg-white hover:bg-brand-primary hover:text-white focus-visible:bg-brand-primary focus-visible:text-white',
  actual_button_type == 'tertiary' ? 'text-white bg-brand-accent border-brand-accent hover:bg-brand-accent-dark hover:border-brand-accent-dark focus-visible:bg-brand-accent-dark focus-visible:border-brand-accent-dark',
] | join(' ') | trim %}

{% set target = open_new_tab ? '_blank' : '_self' %}

<div class="inline-block button-wrapper">
  <a class="{{ classes }}" href="{{ url }}" target="{{ target }}" {{ is_download ? 'download'}}>

    {% if is_download %}
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
    {% endif %}

    <div>{{ title }}</div>
  </a>
</div>
